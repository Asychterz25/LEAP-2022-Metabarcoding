############################
# 12) MANTEL TEST FUNCTION
############################

run_mantel <- function(
    coi_df,
    morph_df,
    sample_ids,
    comparison_name
) {
  
  # Subset
  coi_sub <- coi_df[sample_ids, , drop = FALSE]
  morph_sub <- morph_df[sample_ids, , drop = FALSE]
  
  # Need at least 3 samples
  if(nrow(coi_sub) < 3) {
    
    return(
      data.frame(
        Comparison = comparison_name,
        N_samples = nrow(coi_sub),
        Mantel_r = NA,
        P_value = NA
      )
    )
  }
  
  # Distance matrices
  coi_dist <- vegdist(
    coi_sub,
    method = "jaccard",
    binary = TRUE
  )
  
  morph_dist <- vegdist(
    morph_sub,
    method = "jaccard",
    binary = TRUE
  )
  
  # Mantel
  mantel_res <- mantel(
    coi_dist,
    morph_dist,
    method = "pearson",
    permutations = 999
  )
  
  out <- data.frame(
    Comparison = comparison_name,
    N_samples = nrow(coi_sub),
    Mantel_r = mantel_res$statistic,
    P_value = mantel_res$signif
  )
  
  return(out)
}

