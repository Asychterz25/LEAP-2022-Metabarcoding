############################
# 4) PREPARE DATA FOR JACCARD
############################

process_df_jaccard <- function(df) {
  
  # Find taxon column
  tax_col <- grep(
    "taxon|family|genus",
    names(df),
    ignore.case = TRUE,
    value = TRUE
  )[1]
  
  taxa <- df[[tax_col]]
  
  # Keep only numeric/sample columns
  df_num <- df[, !(names(df) %in% tax_col)]
  
  # Force all columns numeric
  df_num <- df_num %>%
    mutate(across(everything(), as.numeric))
  
  # Convert to presence/absence
  df_pa <- df_num
  
  df_pa[df_pa > 0] <- 1
  df_pa[is.na(df_pa)] <- 0
  
  rownames(df_pa) <- taxa
  
  # Transpose (samples = rows)
  df_pa <- as.data.frame(t(df_pa))
  
  # Ensure numeric after transpose
  df_pa[] <- lapply(df_pa, as.numeric)
  
  # Remove empty samples
  df_pa <- df_pa[rowSums(df_pa) > 0, ]
  
  return(df_pa)
}

