############################
# 6) JACCARD + PCoA FUNCTION
############################

jaccard_pcoa <- function(df, label_name) {
  
  # Jaccard distance
  dist_mat <- vegdist(df, method = "jaccard", binary = TRUE)
  
  # PCoA
  pcoa <- cmdscale(dist_mat, k = 2, eig = TRUE)
  
  var_exp <- round(pcoa$eig / sum(pcoa$eig) * 100, 1)
  
  df_out <- as.data.frame(pcoa$points) %>%
    rename(
      Axis1 = V1,
      Axis2 = V2
    ) %>%
    mutate(
      SampleID = rownames(.),
      Label = label_name,
      Axis1_lab = paste0(
        "Axis 1 (",
        var_exp[1],
        "%)"
      ),
      Axis2_lab = paste0(
        "Axis 2 (",
        var_exp[2],
        "%)"
      )
    )
  
  return(df_out)
}

