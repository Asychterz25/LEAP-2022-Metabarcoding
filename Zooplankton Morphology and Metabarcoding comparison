############################
# 3) COLLAPSE COI REPLICATES
############################

collapse_coi_replicates <- function(df) {
  
  # Find taxon column
  tax_col <- grep(
    "taxon|family|genus",
    names(df),
    ignore.case = TRUE,
    value = TRUE
  )[1]
  
  taxa <- df[[tax_col]]
  
  df_num <- df[, !(names(df) %in% tax_col)]
  
  # Remove replicate suffix
  new_names <- gsub("_R[0-9]+$", "", names(df_num))
  
  # Sum replicates
  df_collapsed <- rowsum(
    t(as.matrix(df_num)),
    group = new_names
  )
  
  df_collapsed <- as.data.frame(t(df_collapsed))
  
  df_final <- cbind(
    Taxa = taxa,
    df_collapsed
  )
  
  return(df_final)
}

