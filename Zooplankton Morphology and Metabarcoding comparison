plot_pcoa <- function(df, title_name) {
  
  x_lab <- unique(df$Axis1_lab)
  y_lab <- unique(df$Axis2_lab)
  
  ggplot(df, aes(x = Axis1, y = Axis2)) +
    geom_point(size = 3) +
    theme_minimal() +
    theme(
      panel.grid = element_blank(),
      panel.border = element_rect(
        color = "black",
        fill = NA
      ),
      plot.title = element_text(
        hjust = 0.5,
        face = "bold"
      )
    ) +
    labs(
      x = x_lab,
      y = y_lab,
      title = title_name
    )
}

